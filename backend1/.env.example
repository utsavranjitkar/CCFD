# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/ccfd_db

# JWT Authentication
SECRET_KEY=your_secret_key_here_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Admin Registration
ADMIN_SECRET=your_admin_secret_code_here

# Model Artifacts Path (optional, defaults to app/model_artifacts/)
MODEL_ARTIFACTS_PATH=app/model_artifacts